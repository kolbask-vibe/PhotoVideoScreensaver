<Window x:Class="VideoScreensaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Height="350" Width="525" Cursor="None" Title="PhotoVideoScreensaver"
        WindowStyle="None" Background="Black"
        KeyDown="ScrKeyDown" Loaded="OnLoaded">
    <Grid>
        <Image Name="FullScreenImage" Stretch="Uniform" />
        <vlc:VideoView x:Name="VlcVideoView" Visibility="Collapsed" Background="Black" />
        <Border Name="InputOverlay" Background="Transparent" Panel.ZIndex="100"
                />
        <TextBlock Name="ErrorText" FontSize="24" TextWrapping="Wrap" Foreground="White"
                   Visibility="Hidden" Margin="10" Panel.ZIndex="200">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="0" Color="Black" Opacity="1" BlurRadius="5"/>
            </TextBlock.Effect>
        </TextBlock>
        <TextBlock Name="Overlay" FontSize="24" TextWrapping="Wrap" Foreground="White"
                   Visibility="Hidden" HorizontalAlignment="Right" Margin="10" Panel.ZIndex="200">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="0" Color="Black" Opacity="1" BlurRadius="5"/>
            </TextBlock.Effect>
        </TextBlock>
        <TextBlock Name="IndexingOverlay" Text="Please wait, files are indexing" FontSize="24" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Panel.ZIndex="300">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="0" Color="Black" Opacity="1" BlurRadius="5"/>
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</Window>